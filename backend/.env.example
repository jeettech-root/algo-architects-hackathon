MODEL_PATH=model.pkl
CORS_ORIGINS=*

# Optional fallback. If omitted, the backend uses only the bundled ML model
# unless Vertex AI is configured below.
GOOGLE_API_KEY=your_google_ai_studio_api_key

# Optional Vertex AI fraud detection.
GCP_PROJECT_ID=your-google-cloud-project-id
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/vertex-service-account.json
VERTEX_MODEL=gemini-2.5-flash
